///////////////////////////////////////////////////////
// ENUMS
///////////////////////////////////////////////////////

Enum invitation_status {
  draft
  trial
  active
  expired
}

Enum payment_status {
  pending
  success
  failed
  expired
}

Enum photo_type {
  groom
  bride
  prewed
}

Enum guest_role {
  primary
  regular
}

///////////////////////////////////////////////////////
// AUTH USERS (representasi auth.users Supabase)
///////////////////////////////////////////////////////

Table users {
  id         uuid [pk, note: 'Supabase auth.users.id']
  email      text [not null]
  created_at timestamptz [default: `now()`]
}

///////////////////////////////////////////////////////
// PROFILES
///////////////////////////////////////////////////////

Table profiles {
  id         uuid [pk, ref: > users.id]
  full_name  text
  username   text [unique]
  email      text [not null]
  avatar_url text
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
}

///////////////////////////////////////////////////////
// THEMES
///////////////////////////////////////////////////////

Table themes {
  id             text [pk]
  name           text [not null]
  description    text
  thumbnail_url  text
  style_tags     text[]
  price          integer [default: 49000]
  original_price integer [default: 99000]
  is_active      boolean [default: true]
  created_at     timestamptz [default: `now()`]
  updated_at     timestamptz [default: `now()`]
}

///////////////////////////////////////////////////////
// INVITATIONS
///////////////////////////////////////////////////////

Table invitations {
  id                        uuid [pk]
  user_id                   uuid [not null, ref: > profiles.id]
  theme_id                  text [ref: > themes.id]
  slug                      text [not null, unique]
  title                     text

  groom_full_name           text
  groom_nickname            text
  groom_father_name         text
  groom_mother_name         text

  bride_full_name           text
  bride_nickname            text
  bride_father_name         text
  bride_mother_name         text

  akad_datetime             timestamptz
  akad_location_name        text
  akad_location_address     text

  resepsi_datetime          timestamptz
  resepsi_location_name     text
  resepsi_location_address  text

  quote_text                text
  gift_bank_name            text
  gift_bank_account         text
  gift_bank_account_name    text
  gift_shipping_address     text

  show_couple_photos        boolean [default: true]
  show_prewed_gallery       boolean [default: true]
  show_gift_section         boolean [default: true]

  status                    invitation_status [default: 'draft']
  is_paid                   boolean [default: false]
  paid_at                   timestamptz
  trial_expires_at          timestamptz
  unpaid_hard_delete_at     timestamptz
  soft_delete_at            timestamptz

  created_at                timestamptz [default: `now()`]
  updated_at                timestamptz [default: `now()`]
}

///////////////////////////////////////////////////////
// GUEST SESSIONS
///////////////////////////////////////////////////////

Table guest_sessions {
  id                         uuid [pk]
  session_token              text [not null, unique]
  slug                       text [not null, unique]
  theme_id                   text [ref: > themes.id]
  invitation_data            jsonb [not null]
  expires_at                 timestamptz [not null]
  created_at                 timestamptz [default: `now()`]
  converted_to_invitation_id uuid [ref: > invitations.id]
}

///////////////////////////////////////////////////////
// INVITATION PHOTOS
///////////////////////////////////////////////////////

Table invitation_photos {
  id            uuid [pk]
  invitation_id uuid [not null, ref: > invitations.id]
  type          photo_type [not null]
  url           text [not null]
  sort_order    integer [default: 0]
  created_at    timestamptz [default: `now()`]
}

///////////////////////////////////////////////////////
// GUESTS
///////////////////////////////////////////////////////

Table guests {
  id            uuid [pk]
  invitation_id uuid [not null, ref: > invitations.id]
  name          text [not null]
  phone_number  text
  email         text
  role          guest_role [default: 'regular']
  notes         text
  created_at    timestamptz [default: `now()`]
}

///////////////////////////////////////////////////////
// RSVP
///////////////////////////////////////////////////////

Table rsvp {
  id               uuid [pk]
  invitation_id    uuid [not null, ref: > invitations.id]
  guest_id         uuid [ref: > guests.id]
  guest_name       text [not null]
  phone_number     text
  message          text
  attend_akad      boolean [default: false]
  attend_resepsi   boolean [default: false]
  number_of_guests integer [default: 1]
  created_at       timestamptz [default: `now()`]
}

///////////////////////////////////////////////////////
// MESSAGES
///////////////////////////////////////////////////////

Table messages {
  id            uuid [pk]
  invitation_id uuid [not null, ref: > invitations.id]
  guest_name    text [not null]
  message       text [not null]
  created_at    timestamptz [default: `now()`]
}

///////////////////////////////////////////////////////
// PAYMENTS
///////////////////////////////////////////////////////

Table payments {
  id                     uuid [pk]
  invitation_id          uuid [not null, ref: > invitations.id]
  user_id                uuid [not null, ref: > profiles.id]
  amount                 integer [not null]
  currency               text [default: 'IDR']
  payment_gateway        text [default: 'midtrans']
  gateway_transaction_id text [unique]
  status                 payment_status [default: 'pending']
  paid_at                timestamptz
  expires_at             timestamptz
  created_at             timestamptz [default: `now()`]
}

///////////////////////////////////////////////////////
// ANALYTICS EVENTS
///////////////////////////////////////////////////////

Table analytics_events {
  id            uuid [pk]
  invitation_id uuid [ref: > invitations.id]
  event_name    text
  meta          jsonb
  created_at    timestamptz [default: `now()`]
}
